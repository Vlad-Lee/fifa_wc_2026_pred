# Generated pipeline artifacts (reproducible - regenerated by the scripts)
data/processed/modeling/modeling_matrices_package.zip
data/processed/modeling/wc2026_predictions.csv
data/processed/modeling/final_elo_ratings.json

# Model artifact tracked on purpose: a deployed Streamlit app cannot run the
# fitting scripts, so this small JSON file must ship with the repo.
#   data/processed/modeling/dixon_coles_params.json   (the fitted model)

# Streamlit's on-disk cache (from @st.cache_data persist="disk")
.streamlit/cache/

